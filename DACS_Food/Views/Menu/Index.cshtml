@{
    ViewData["Title"] = "Thực đơn";
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/menu.css" asp-append-version="true" />
}

<section class="menu-page-hero">
    <div class="container menu-hero-inner">
        <div>
            <p class="section-eyebrow">FoodieTTTM menu</p>
            <h1>Thực đơn riêng cho món ăn & đồ uống</h1>
        </div>
    </div>
</section>

<section class="menu-catalog-section" id="menuCatalog">
    <div class="container">
        @* Phan filter va grid nay thuoc chuc nang Mon an; du lieu duoc menu.js nap tu API /api/foods. *@
        <div class="menu-toolbar">
            <div>
                <h2>Danh mục món</h2>
                <p id="menuResultText">Đang hiển thị tất cả món.</p>
            </div>
            <div class="menu-filter-buttons" aria-label="Lọc thực đơn">
                <button class="active" type="button" data-category="all">Tất cả</button>
                <button type="button" data-category="Món mặn">Món mặn</button>
                <button type="button" data-category="Món chay">Món chay</button>
                <button type="button" data-category="Healthy">Healthy</button>
                <button type="button" data-category="Đồ uống">Đồ uống</button>
            </div>
        </div>

        <div class="menu-grid" id="dedicatedMenuGrid"></div>
    </div>
</section>

@* Modal chi tiet mon an hien thi thanh phan, cau chuyen mon va ghi chu di ung/an toan. *@
<div class="menu-detail-modal" id="menuDetailModal" aria-hidden="true">
    <div class="menu-detail-backdrop" onclick="closeMenuDetail()"></div>
    <article class="menu-detail-dialog" role="dialog" aria-modal="true" aria-labelledby="menuDetailName">
        <button class="menu-detail-close" type="button" onclick="closeMenuDetail()" aria-label="Đóng">×</button>
        <div class="menu-detail-media">
            <img id="menuDetailImage" src="" alt="" />
            <span id="menuDetailCategory"></span>
        </div>
        <div class="menu-detail-content">
            <p class="section-eyebrow" id="menuDetailSubcategory"></p>
            <h2 id="menuDetailName"></h2>
            <strong id="menuDetailPrice"></strong>
            <p id="menuDetailDescription"></p>
            <div class="menu-detail-block">
                <h3>Câu chuyện món ăn</h3>
                <p id="menuDetailStory"></p>
            </div>
            <div class="menu-detail-block">
                <h3>Thành phần chính</h3>
                <ul id="menuDetailIngredients"></ul>
            </div>
            <div class="menu-detail-alert">
                <h3>Ghi chú dị ứng/an toàn thực phẩm</h3>
                <p id="menuDetailAllergy"></p>
            </div>
            <button class="btn btn-primary full-btn" type="button" id="menuDetailAction">Thêm vào giỏ hàng</button>
        </div>
    </article>
</div>

@section Scripts {
    <script src="~/assets/js/menu.js" asp-append-version="true"></script>
}

