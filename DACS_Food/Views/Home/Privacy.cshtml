@{ ViewData["Title"] = "Chính sách bảo mật"; }

<section class="page-hero">
    <div class="container">
        <div class="badge">🔒 Chính sách bảo mật</div>
        <h1>FoodieTTTM bảo vệ thông tin của bạn</h1>
        <p>Chính sách này giải thích cách FoodieTTTM sử dụng thông tin khi bạn đặt món, đặt bàn hoặc tạo tài khoản.</p>
    </div>
</section>

<section class="section section-light">
    <div class="container simple-grid">
        <div class="simple-card">
            <h3>Thông tin được thu thập</h3>
            <p>FoodieTTTM có thể lưu họ tên, email, số điện thoại, địa chỉ giao hàng, lịch sử đơn hàng và thông tin đặt bàn để phục vụ khách tốt hơn.</p>
        </div>
        <div class="simple-card">
            <h3>Mục đích sử dụng</h3>
            <p>Thông tin được dùng để xác nhận đơn, giao món, hỗ trợ đổi thông tin đặt bàn, gửi OTP Gmail và quản lý ưu đãi thành viên.</p>
        </div>
        <div class="simple-card">
            <h3>Bảo mật tài khoản</h3>
            <p>Mật khẩu được xử lý qua hệ thống Identity. OTP có thời hạn ngắn và được giới hạn tần suất gửi để tránh spam hoặc lạm dụng.</p>
        </div>
        <div class="simple-card">
            <h3>Chia sẻ thông tin</h3>
            <p>FoodieTTTM không bán thông tin cá nhân. Thông tin chỉ được dùng nội bộ cho việc xác nhận, giao hàng và chăm sóc khách hàng.</p>
        </div>
        <div class="simple-card">
            <h3>Quyền của khách hàng</h3>
            <p>Bạn có thể yêu cầu kiểm tra, cập nhật hoặc xóa thông tin liên hệ bằng cách gọi hotline YOUR_SUPPORT_PHONE hoặc nhắn Facebook/Zalo FoodieTTTM.</p>
        </div>
        <div class="simple-card">
            <h3>Liên hệ</h3>
            <p>Nếu có thắc mắc về bảo mật, vui lòng liên hệ FoodieTTTM để được hỗ trợ rõ ràng và kịp thời.</p>
        </div>
    </div>
</section>

