@model DACS_Food.ViewModels.TablePageViewModel
@using DACS_Food.Models
@{
    ViewData["Title"] = "Đặt bàn & Không gian";
    var availableTables = Model.Tables.Count(x => !x.IsBusy);
    var busyTables = Model.Tables.Count(x => x.IsBusy);
    var privateTables = Model.Tables.Count(x => x.TableType == TableType.Private);
    var pendingReservations = Model.Reservations.Count(x => x.Status == ReservationStatus.Pending);
    var confirmedReservations = Model.Reservations.Count(x => x.Status == ReservationStatus.Confirmed);
    var suggestedFoods = Model.SuggestedFoodItems;
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/reservation.css" asp-append-version="true" />
}

<section class="reservation-hero">
    <div class="container reservation-hero-grid">
        <div class="reservation-hero-copy">
            <p class="section-eyebrow">FoodieTTTM reservation</p>
            <h1>Đặt bàn nhanh, chọn đúng không gian trước khi đến quán</h1>
            <p>Chọn bàn, ngày và khung giờ phù hợp. Nhân viên sẽ gọi lại để xác nhận lịch và ghi chú phục vụ.</p>
        </div>
        <div class="reservation-hero-panel">
            <div>
                <span>@availableTables</span>
                <p>Bàn còn trống</p>
            </div>
            <div>
                <span>@busyTables</span>
                <p>Bàn đang bận</p>
            </div>
            <div>
                <span>@privateTables</span>
                <p>Bàn private</p>
            </div>
        </div>
    </div>
</section>

<section class="reservation-section">
    <div class="container">
        @if (TempData["TableMessage"] is string message)
        {
            <p class="reservation-notice">@message</p>
        }

        <div class="reservation-layout">
            <div class="reservation-floor">
                <div class="reservation-section-head">
                    <div>
                        <p class="section-eyebrow">Sơ đồ bàn</p>
                        <h2>Tình trạng bàn hiện tại</h2>
                    </div>
                    <div class="reservation-legend">
                        <span><i class="is-open"></i>Còn trống</span>
                        <span><i class="is-busy"></i>Đang bận</span>
                    </div>
                </div>

                <div class="reservation-table-grid">
                    @foreach (var table in Model.Tables)
                    {
                        var statusClass = table.IsBusy ? "is-busy" : "is-open";
                        var tableTypeLabel = table.TableType == TableType.Private ? "Private" : "Thường";
                        <button type="button"
                                class="reservation-table-card @statusClass"
                                data-reservation-table-id="@table.Id"
                                onclick="selectReservationTable(@table.Id)"
                                aria-label="Chọn bàn @table.TableNumber">
                            <span class="reservation-table-status">@(table.IsBusy ? "Đang bận" : "Còn trống")</span>
                            <strong>Bàn @table.TableNumber</strong>
                            <small>@tableTypeLabel</small>
                            <em>@table.Capacity người</em>
                        </button>
                    }
                </div>
            </div>

            <aside class="reservation-side">
                @if (!User.IsInRole("Admin"))
                {
                    <form class="reservation-form-card" id="publicReservationForm" method="post" action="/ban/dat-ban">
                        <div class="reservation-card-title">
                            <p class="section-eyebrow">Yêu cầu đặt bàn</p>
                            <h2>Giữ chỗ cho bữa ăn của bạn</h2>
                        </div>
                        <div class="reservation-form-grid">
                            <label>
                                <span>Ngày đến</span>
                                <input id="publicReservationDate" name="ReservationDate" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </label>
                            <label>
                                <span>Bàn muốn đặt</span>
                                <select id="publicTableId" name="TableId" required>
                                    @foreach (var table in Model.Tables)
                                    {
                                        <option value="@table.Id">Bàn @table.TableNumber - @(table.TableType == TableType.Private ? "Private" : "Thường") - @table.Capacity người</option>
                                    }
                                </select>
                            </label>
                            <label>
                                <span>Khung giờ</span>
                                <select id="publicTimeSlot" name="TimeSlot" required hidden>
                                    <option value="">Chọn ngày và bàn để tải khung giờ</option>
                                </select>
                            </label>
                            <label>
                                <span>Họ tên</span>
                                <input name="CustomerName" placeholder="Nguyễn Văn A" required />
                            </label>
                            <label>
                                <span>Số điện thoại</span>
                                <input name="PhoneNumber" placeholder="0900000000" required />
                            </label>
                            <label>
                                <span>Ghi chú</span>
                                <textarea name="Note" rows="3" placeholder="Sinh nhật, ghế trẻ em, vị trí yên tĩnh..."></textarea>
                            </label>
                            @if (suggestedFoods.Any())
                            {
                                <div class="reservation-food-picker">
                                    <div class="reservation-food-head">
                                        <span>Chọn món trước</span>
                                        <small>Nhân viên sẽ chuẩn bị gợi ý này khi xác nhận bàn</small>
                                    </div>
                                    <div class="reservation-food-grid">
                                        @foreach (var food in suggestedFoods)
                                        {
                                            <label class="reservation-food-choice">
                                                <input type="checkbox" name="SelectedFoodItemIds" value="@food.Id" />
                                                <span class="reservation-food-image">
                                                    <img src="@food.ImageUrl" alt="@food.Name" />
                                                </span>
                                                <span class="reservation-food-copy">
                                                    <strong>@food.Name</strong>
                                                    <small>@food.Category • @food.Price.ToString("N0")đ</small>
                                                </span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <p class="reservation-feedback" id="publicReservationFeedback" aria-live="polite" hidden></p>
                        <button class="btn btn-primary reservation-submit" type="submit">Gửi yêu cầu đặt bàn</button>
                    </form>

                    <div class="reservation-info-card">
                        <p class="section-eyebrow">Quy trình xác nhận</p>
                        <h3>Sau khi gửi yêu cầu</h3>
                        <div class="reservation-steps">
                            <span>Nhân viên kiểm tra bàn và khung giờ.</span>
                            <span>Quán gọi lại để xác nhận thông tin.</span>
                            <span>Đến đúng giờ để giữ trải nghiệm tốt nhất.</span>
                        </div>
                    </div>
                }
                else
                {
                    <form class="reservation-form-card" method="post" action="/ban/dat-ban">
                        <div class="reservation-card-title">
                            <p class="section-eyebrow">Admin reservation</p>
                            <h2>Tạo lịch đặt bàn</h2>
                        </div>
                        <div class="reservation-form-grid">
                            <label>
                                <span>Ngày đặt</span>
                                <input id="reservationDate" name="ReservationDate" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </label>
                            <label>
                                <span>Bàn</span>
                                <select id="tableId" name="TableId" required>
                                    @foreach (var table in Model.Tables)
                                    {
                                        <option value="@table.Id">Bàn @table.TableNumber - @(table.TableType == TableType.Private ? "Private" : "Thường") - @table.Capacity người</option>
                                    }
                                </select>
                            </label>
                            <label>
                                <span>Khung giờ</span>
                                <select id="timeSlot" name="TimeSlot" required>
                                    <option value="">Chọn ngày và bàn để tải khung giờ</option>
                                </select>
                            </label>
                            <label>
                                <span>Tên khách</span>
                                <input name="CustomerName" placeholder="Tên khách" required />
                            </label>
                            <label>
                                <span>Số điện thoại</span>
                                <input name="PhoneNumber" placeholder="Số điện thoại" required />
                            </label>
                            <label>
                                <span>Ghi chú</span>
                                <textarea name="Note" rows="3" placeholder="Ghi chú nếu có"></textarea>
                            </label>
                            @if (suggestedFoods.Any())
                            {
                                <div class="reservation-food-picker">
                                    <div class="reservation-food-head">
                                        <span>Chọn món trước</span>
                                        <small>Gắn món khách muốn ăn vào ghi chú đặt bàn</small>
                                    </div>
                                    <div class="reservation-food-grid">
                                        @foreach (var food in suggestedFoods)
                                        {
                                            <label class="reservation-food-choice">
                                                <input type="checkbox" name="SelectedFoodItemIds" value="@food.Id" />
                                                <span class="reservation-food-image">
                                                    <img src="@food.ImageUrl" alt="@food.Name" />
                                                </span>
                                                <span class="reservation-food-copy">
                                                    <strong>@food.Name</strong>
                                                    <small>@food.Category • @food.Price.ToString("N0")đ</small>
                                                </span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                            <label>
                                <span>Trạng thái</span>
                                <select name="Status">
                                    <option value="@ReservationStatus.Pending">Pending</option>
                                    <option value="@ReservationStatus.Confirmed">Confirmed</option>
                                </select>
                            </label>
                        </div>
                        <button class="btn btn-primary reservation-submit" type="submit">Tạo lịch đặt bàn</button>
                    </form>

                    <div class="reservation-info-card reservation-admin-card">
                        <div class="reservation-admin-stats">
                            <div><strong>@pendingReservations</strong><span>Pending</span></div>
                            <div><strong>@confirmedReservations</strong><span>Confirmed</span></div>
                        </div>
                        <h3>Lịch gần nhất</h3>
                        <div class="reservation-admin-list">
                            @if (!Model.Reservations.Any())
                            {
                                <span>Chưa có lịch đặt bàn cần xử lý.</span>
                            }
                            @foreach (var reservation in Model.Reservations.Take(6))
                            {
                                var reservationStatusClass = reservation.Status == ReservationStatus.Confirmed ? "confirmed" : "pending";
                                <div class="reservation-admin-item @reservationStatusClass">
                                    <b>Bàn @reservation.RestaurantTable?.TableNumber</b>
                                    <span>@reservation.StartAt.ToString("dd/MM HH:mm") - @reservation.CustomerName</span>
                                    @if (!string.IsNullOrWhiteSpace(reservation.Note))
                                    {
                                        <small>@reservation.Note</small>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</section>

@if (User.IsInRole("Admin"))
{
    @section Scripts {
        <script>
            function setActiveReservationCard(tableId) {
                document.querySelectorAll('[data-reservation-table-id]').forEach(card => {
                    card.classList.toggle('is-selected', card.dataset.reservationTableId === String(tableId));
                });
            }

            function selectReservationTable(tableId) {
                const tableInput = document.getElementById('tableId');
                if (!tableInput) return;
                tableInput.value = tableId;
                setActiveReservationCard(tableId);
                loadReservationSlots();
            }

            async function loadReservationSlots() {
                const dateInput = document.getElementById('reservationDate');
                const tableInput = document.getElementById('tableId');
                const slotInput = document.getElementById('timeSlot');
                if (!dateInput || !tableInput || !slotInput || !dateInput.value || !tableInput.value) return;

                slotInput.innerHTML = '<option value="">Đang tải khung giờ...</option>';
                const response = await fetch(`/ban/khung-gio?date=${encodeURIComponent(dateInput.value)}&tableId=${encodeURIComponent(tableInput.value)}`);
                const slots = await response.json();
                slotInput.innerHTML = slots.map(slot =>
                    `<option value="${slot.time}" ${slot.isAvailable ? '' : 'disabled'}>${slot.label}</option>`
                ).join('');
                setActiveReservationCard(tableInput.value);
            }

            document.addEventListener('DOMContentLoaded', () => {
                const dateInput = document.getElementById('reservationDate');
                const tableInput = document.getElementById('tableId');
                if (dateInput) dateInput.addEventListener('change', loadReservationSlots);
                if (tableInput) tableInput.addEventListener('change', loadReservationSlots);
                loadReservationSlots();
            });
        </script>
    }
}
else
{
    @section Scripts {
        <script>
            function setActiveReservationCard(tableId) {
                document.querySelectorAll('[data-reservation-table-id]').forEach(card => {
                    card.classList.toggle('is-selected', card.dataset.reservationTableId === String(tableId));
                });
            }

            function selectReservationTable(tableId) {
                const tableInput = document.getElementById('publicTableId');
                if (!tableInput) return;
                tableInput.value = tableId;
                setActiveReservationCard(tableId);
                loadPublicReservationSlots();
            }

            async function loadPublicReservationSlots() {
                const dateInput = document.getElementById('publicReservationDate');
                const tableInput = document.getElementById('publicTableId');
                const slotInput = document.getElementById('publicTimeSlot');
                if (!dateInput || !tableInput || !slotInput || !dateInput.value || !tableInput.value) return;

                slotInput.hidden = false;
                slotInput.innerHTML = '<option value="">Đang tải khung giờ...</option>';
                try {
                    const response = await fetch(`/api/tables/${encodeURIComponent(tableInput.value)}/slots?date=${encodeURIComponent(dateInput.value)}`);
                    const slots = await response.json();
                    slotInput.innerHTML = slots.map(slot =>
                        `<option value="${slot.time}" ${slot.isAvailable ? '' : 'disabled'}>${slot.label}</option>`
                    ).join('');
                    setActiveReservationCard(tableInput.value);
                } catch {
                    slotInput.innerHTML = '<option value="">Không tải được khung giờ</option>';
                }
            }

            async function submitPublicReservation(event) {
                event.preventDefault();
                const form = event.currentTarget;
                const submitButton = form.querySelector('button[type="submit"]');
                const feedback = document.getElementById('publicReservationFeedback');
                const dateInput = document.getElementById('publicReservationDate');
                const slotInput = document.getElementById('publicTimeSlot');
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());
                const selectedFoodItemIds = formData
                    .getAll('SelectedFoodItemIds')
                    .map(value => Number(value))
                    .filter(value => Number.isInteger(value) && value > 0);

                if (submitButton) submitButton.disabled = true;
                if (feedback) {
                    feedback.hidden = false;
                    feedback.classList.remove('success', 'danger');
                    feedback.textContent = 'Đang gửi yêu cầu đặt bàn...';
                }
                try {
                    const response = await fetch('/api/tables/reservations', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            reservationDate: data.ReservationDate,
                            tableId: Number(data.TableId),
                            timeSlot: data.TimeSlot,
                            customerName: data.CustomerName,
                            phoneNumber: data.PhoneNumber,
                            note: data.Note || '',
                            selectedFoodItemIds
                        })
                    });
                    const result = await response.json();
                    if (feedback) {
                        feedback.classList.toggle('success', response.ok);
                        feedback.classList.toggle('danger', !response.ok);
                        feedback.textContent = result.message || (response.ok ? 'Đã gửi yêu cầu đặt bàn. Yêu cầu đang chờ nhân viên xác nhận.' : 'Không gửi được yêu cầu đặt bàn.');
                    }
                    if (response.ok) {
                        form.reset();
                        const today = new Date().toISOString().slice(0, 10);
                        if (dateInput) dateInput.value = today;
                        if (slotInput) {
                            slotInput.hidden = true;
                            slotInput.innerHTML = '<option value="">Chọn ngày và bàn để tải khung giờ</option>';
                        }
                        loadPublicReservationSlots();
                    }
                } catch {
                    if (feedback) {
                        feedback.hidden = false;
                        feedback.classList.add('danger');
                        feedback.textContent = 'Không gửi được yêu cầu đặt bàn. Vui lòng thử lại sau.';
                    }
                } finally {
                    if (submitButton) submitButton.disabled = false;
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const form = document.getElementById('publicReservationForm');
                const dateInput = document.getElementById('publicReservationDate');
                const tableInput = document.getElementById('publicTableId');
                if (form) form.addEventListener('submit', submitPublicReservation);
                if (dateInput) dateInput.addEventListener('change', loadPublicReservationSlots);
                if (tableInput) tableInput.addEventListener('change', loadPublicReservationSlots);
                loadPublicReservationSlots();
            });
        </script>
    }
}
