@{
    ViewData["Title"] = "Đã gửi hướng dẫn";
}

<section class="auth-page">
    <div class="container auth-shell">
        <div class="auth-intro">
            <div class="badge">FoodieLab account</div>
            <h1>Kiểm tra email của bạn</h1>
            <p>Nếu email tồn tại trong hệ thống, chúng tôi đã gửi hướng dẫn đặt lại mật khẩu.</p>
        </div>

        <div class="auth-card auth-login-card">
            <span class="auth-eyebrow">Bảo mật tài khoản</span>
            <h3>Hướng dẫn đã được xử lý</h3>
            <p>Link đặt lại mật khẩu chỉ có hiệu lực trong 30 phút. Nếu không thấy email, hãy kiểm tra thư rác hoặc thử lại sau ít phút.</p>
            <a class="btn btn-primary full-btn" href="/dang-nhap">Quay lại đăng nhập</a>
        </div>
    </div>
</section>
