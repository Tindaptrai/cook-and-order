@model string
@{
    ViewData["Title"] = "Kết quả đặt lại mật khẩu";
    var message = Model ?? "Đặt lại mật khẩu thành công. Vui lòng đăng nhập bằng mật khẩu mới.";
    var isError = message.Contains("không hợp lệ") || message.Contains("hết hạn");
}

<section class="auth-page">
    <div class="container auth-shell">
        <div class="auth-intro">
            <div class="badge">FoodieLab account</div>
            <h1>@(isError ? "Liên kết không hợp lệ" : "Đặt lại mật khẩu thành công")</h1>
            <p>@message</p>
        </div>

        <div class="auth-card auth-login-card">
            <span class="auth-eyebrow">Tài khoản FoodieLab</span>
            <h3>@(isError ? "Vui lòng yêu cầu link mới" : "Bạn có thể đăng nhập lại")</h3>
            <p>@(isError ? "Để bảo vệ tài khoản, link đặt lại mật khẩu chỉ dùng một lần và có thời hạn ngắn." : "Mật khẩu cũ không còn dùng được sau khi đặt lại thành công.")</p>
            <a class="btn btn-primary full-btn" href="@(isError ? "/Account/ForgotPassword" : "/dang-nhap")">@(isError ? "Yêu cầu link mới" : "Đăng nhập")</a>
        </div>
    </div>
</section>
