@model DACS_Food.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    var hasPassword = ViewBag.HasPassword as bool? ?? true;
    var otpSent = ViewBag.OtpSent as bool? ?? false;
    var email = ViewBag.Email as string ?? "email tài khoản";
}

<section class="page-hero">
    <div class="container">
        <div class="badge">Bảo mật tài khoản</div>
        <h1>Đổi mật khẩu</h1>
        <p>Xác minh mật khẩu và email trước khi cập nhật mật khẩu mới cho tài khoản FoodieTTTM.</p>
    </div>
</section>

<section class="section section-light">
    <div class="container">
        <div class="checkout-layout">
            <form class="checkout-card light" method="post" action="/tai-khoan/doi-mat-khau/gui-otp">
                @Html.AntiForgeryToken()
                <h3>Thông tin mật khẩu</h3>
                <p>Nhập đúng thông tin bên dưới, hệ thống mới gửi mã OTP về @email.</p>
                <div class="auth-validation" asp-validation-summary="All"></div>
                @if (TempData["PasswordMessage"] != null)
                {
                    <p class="form-success">@TempData["PasswordMessage"]</p>
                }

                <div class="form-group">
                    @if (hasPassword)
                    {
                        <label asp-for="CurrentPassword">Mật khẩu hiện tại</label>
                        <input asp-for="CurrentPassword" type="password" placeholder="Nhập mật khẩu hiện tại" autocomplete="current-password" />
                    }
                    else
                    {
                        <p>Tài khoản này đăng nhập bằng Google nên chưa có mật khẩu riêng.</p>
                    }

                    <label asp-for="NewPassword">Mật khẩu mới</label>
                    <input asp-for="NewPassword" type="password" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />

                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />

                    <button class="btn btn-primary" type="submit">Kiểm tra và gửi OTP</button>
                </div>
            </form>

            <div class="checkout-card">
                <h3>Xác nhận OTP</h3>
                <p>Mã OTP gồm 8 chữ số và có hiệu lực trong 5 phút. Nếu đổi lại mật khẩu mới, hãy gửi mã OTP mới.</p>
                @if (!otpSent)
                {
                    <div class="notice">Hoàn tất bước nhập mật khẩu trước để nhận OTP.</div>
                }
                <form class="form-group" method="post" action="/tai-khoan/doi-mat-khau">
                    @Html.AntiForgeryToken()
                    <label for="Code">Mã OTP</label>
                    <input id="Code" name="Code" inputmode="numeric" maxlength="8" placeholder="Nhập 8 chữ số trong email" autocomplete="one-time-code" required @(otpSent ? "" : "disabled") />
                    <button class="btn btn-primary" type="submit" @(otpSent ? "" : "disabled")>Đổi mật khẩu</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
