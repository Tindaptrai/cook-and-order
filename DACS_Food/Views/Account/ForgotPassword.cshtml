@model DACS_Food.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-page">
    <div class="container auth-shell">
        <div class="auth-intro">
            <div class="badge">FoodieLab account</div>
            <h1>Quên mật khẩu</h1>
            <p>Nhập email đã đăng ký. Nếu email tồn tại trong hệ thống, FoodieLab sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        </div>

        <form class="auth-card auth-login-card" method="post">
            @Html.AntiForgeryToken()
            <span class="auth-eyebrow">Khôi phục tài khoản</span>
            <h3>Nhận link đặt lại mật khẩu</h3>
            <p>Liên kết đặt lại mật khẩu có hiệu lực trong 30 phút.</p>
            <div class="auth-validation" asp-validation-summary="All"></div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="ten@email.com" />
                <button class="btn btn-primary" type="submit">Gửi hướng dẫn</button>
            </div>
            <div class="auth-card-footer">
                <span>Đã nhớ mật khẩu?</span>
                <a href="/dang-nhap">Đăng nhập</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
