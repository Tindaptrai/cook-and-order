@{
    ViewData["Title"] = "Cách chọn thực phẩm";
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/food-guide.css" asp-append-version="true" />
}

<section class="food-guide-hero">
    <div class="container food-guide-hero-inner">
        <div class="food-guide-hero-copy">
            <p class="section-eyebrow">FoodieTTTM fresh guide</p>
            <h1>Chọn thực phẩm tươi, sạch và an toàn hơn mỗi ngày</h1>
            <p>Cẩm nang giúp khách nhận biết nguyên liệu nên mua, dấu hiệu cần tránh và cách bảo quản phù hợp trước khi chế biến.</p>
        </div>
        <div class="food-guide-hero-panel">
            <div><strong>32</strong><span>Thực phẩm</span></div>
            <div><strong>7</strong><span>Nhóm nguyên liệu</span></div>
            <div><strong>4</strong><span>Tiêu chí kiểm tra</span></div>
        </div>
    </div>
</section>

<section class="food-guide-section" id="foodGuideCatalog">
    <div class="container">
        <div class="food-guide-command">
            <div>
                <p class="section-eyebrow">Tra cứu nhanh</p>
                <h2>Danh sách thực phẩm</h2>
                <p id="foodGuideResultText">Đang hiển thị tất cả thực phẩm.</p>
            </div>
            <label class="food-guide-search">
                <span>Tìm nhanh</span>
                <input id="foodGuideSearchInput" type="search" placeholder="Nhập: cà chua, tomato, pork..." />
            </label>
        </div>

        <div class="food-guide-filters" aria-label="Lọc nhóm thực phẩm">
            <button class="active" type="button" data-category="all">Tất cả</button>
            <button type="button" data-category="rau-cu">Rau củ</button>
            <button type="button" data-category="trai-cay">Trái cây</button>
            <button type="button" data-category="thit">Thịt</button>
            <button type="button" data-category="ca-hai-san">Cá & hải sản</button>
            <button type="button" data-category="trung-sua">Trứng & sữa</button>
            <button type="button" data-category="dau-hat-ngu-coc">Đậu, hạt & ngũ cốc</button>
            <button type="button" data-category="gia-vi-thuc-pham-kho">Gia vị & thực phẩm khô</button>
        </div>

        <div class="food-guide-grid" id="foodGuideGrid"></div>

        <div class="food-guide-safety-note">
            <div>
                <p class="section-eyebrow">Nguyên tắc an toàn</p>
                <h2>Kiểm tra trước khi mua và trước khi nấu</h2>
            </div>
            <div class="food-guide-safety-grid">
                <span>Ưu tiên nguồn gốc rõ ràng, bao bì nguyên vẹn.</span>
                <span>Không dùng thực phẩm đổi màu, nhớt hoặc có mùi lạ.</span>
                <span>Tách riêng thực phẩm sống và chín khi bảo quản.</span>
            </div>
        </div>
    </div>
</section>

<div class="food-guide-modal" id="foodGuideModal" aria-hidden="true">
    <div class="food-guide-modal-backdrop" onclick="closeFoodGuideModal()"></div>
    <article class="food-guide-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="foodGuideModalNameVi">
        <button class="food-guide-modal-close" type="button" onclick="closeFoodGuideModal()" aria-label="Đóng">×</button>
        <div class="food-guide-modal-image">
            <img id="foodGuideModalImage" src="" alt="" />
            <span id="foodGuideModalCategory"></span>
        </div>
        <div class="food-guide-modal-content">
            <p class="section-eyebrow" id="foodGuideModalNameEn"></p>
            <h2 id="foodGuideModalNameVi"></h2>
            <p id="foodGuideModalDesc"></p>
            <div class="food-guide-detail-grid">
                <div class="food-guide-detail-block guide-choose">
                    <h3><span>✓</span> Cách chọn</h3>
                    <ul id="foodGuideModalChooseTips"></ul>
                </div>
                <div class="food-guide-detail-block guide-avoid">
                    <h3><span>!</span> Nên tránh</h3>
                    <ul id="foodGuideModalAvoidSigns"></ul>
                </div>
                <div class="food-guide-detail-block guide-storage">
                    <h3><span>BQ</span> Bảo quản</h3>
                    <ul id="foodGuideModalStorage"></ul>
                </div>
                <div class="food-guide-detail-block guide-safety">
                    <h3><span>AT</span> An toàn</h3>
                    <p id="foodGuideModalSafety"></p>
                </div>
            </div>
        </div>
    </article>
</div>

@section Scripts {
    <script src="~/assets/js/food-guide.js" asp-append-version="true"></script>
}
